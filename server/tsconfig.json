{
  "compilerOptions": {
    "target": "es2016",
    "module": "nodenext",
    "rootDir": ".",
    "moduleResolution": "nodenext",
    "types": ["node"],
    "resolveJsonModule": true,
    "outDir": "./dist",
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "skipLibCheck": true
  }
}
